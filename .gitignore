# Compiled Python files
*.pyc

# Folder view configuration files
.DS_Store
Desktop.ini

# Thumbnail cache files
._*
Thumbs.db

# Files that might appear on external disks
.Spotlight-V100
.Trashes

# Scratch pads
scratch.*

# GPG — only track agent config, never keys or trust database
.gnupg/*
!.gnupg/gpg-agent.conf

# Generated zsh completion cache
.zcompdump

# Claude Code — track user memory, never machine-local settings
.claude/settings.local.json
.claude/CLAUDE.local.md

# Machine-local secrets rendered from .extra.tmpl by `op inject`.
# The template (.extra.tmpl) IS tracked; the rendered output never is.
.extra
