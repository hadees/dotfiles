#!/usr/bin/env zsh

# Preferred editors.
export EDITOR='code --wait'
export GEM_EDITOR='code'

# Enable persistent REPL history for `node`.
export NODE_REPL_HISTORY="$HOME/.node_history"
export NODE_REPL_HISTORY_SIZE='32768'

# Make Python use UTF-8 encoding for input/output streams.
export PYTHONIOENCODING='UTF-8'

# Prefer US English and use UTF-8.
export LANG='en_US.UTF-8'
export LC_ALL='en_US.UTF-8'

# Use bat for man pages when available, otherwise fall back to less.
if (( $+commands[bat] )); then
	export MANPAGER="sh -c 'col -bx | bat -l man -p'"
	export MANROFFOPT='-c'
else
	export MANPAGER='less -X'
fi

# fzf: use fd for file finding, bat for previews.
if (( $+commands[fzf] )); then
	export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
	export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
	export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'
	export FZF_DEFAULT_OPTS='--height 40% --layout=reverse --border'
	if (( $+commands[bat] )); then
		export FZF_CTRL_T_OPTS="--preview 'bat --color=always --style=numbers --line-range=:200 {}'"
	fi
fi

# Homebrew preferences.
typeset -U path PATH
if (( $+commands[brew] )); then
	path=("$(brew --prefix)/sbin" $path)
fi
export PATH
export HOMEBREW_CASK_OPTS='--appdir=/Applications'

# This keeps apple from throwing a forking error.
export OBJC_DISABLE_INITIALIZE_FORK_SAFETY=YES

# Avoid issues with `gpg` as installed via Homebrew.
# https://stackoverflow.com/a/42265848/96656
export GPG_TTY="$(tty)"
