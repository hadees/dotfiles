#!/usr/bin/env zsh

# Shell prompt using Base16 Eighties ANSI colors.
# Relies on the terminal's ANSI palette (colors 0-15) matching Base16 Eighties:
#   yellow  = Base0A #ffcc66  blue    = Base0D #6699cc
#   green   = Base0B #99cc99  cyan    = Base0C #66cccc
#   red     = Base08 #f2777a  magenta = Base0E #cc99cc
#   white   = Base05 #d3d0c8  brblack = Base03 #747369
# Nerd Font glyphs (branch , github , ssh 󰣀) are shown only when
# ~/bin/has-glyphs confirms the terminal font renders them (over ssh: when
# the client is iTerm); other terminals degrade to plain text.

if [[ $COLORTERM = gnome-* && $TERM = xterm ]] && infocmp gnome-256color >/dev/null 2>&1; then
	export TERM='gnome-256color'
elif infocmp xterm-256color >/dev/null 2>&1; then
	export TERM='xterm-256color'
fi

autoload -Uz colors && colors
setopt PROMPT_SUBST

# Nerd Font glyphs. Locally, has-glyphs asks CoreText whether the terminal's
# configured font can actually render them (cached). Over ssh the remote host
# can't inspect the local machine's fonts, so iTerm identity (LC_TERMINAL,
# forwarded by iTerm) stays as the proxy. Either way the fallback is plain
# text.
# nf_github replaces the plain-text "@" rather than adding to it: icons
# stand in for words (cf. oh-my-posh's UpstreamIcon, shown bare before the
# name), so the segment reads " user" with glyphs and "@user" without.
nf_branch='' nf_github='@' nf_ssh='' nf_on=''
if [[ -n $SSH_TTY ]]; then
	[[ $LC_TERMINAL == iTerm2 ]] && nf_on=1
elif [[ -x $HOME/bin/has-glyphs ]]; then
	"$HOME/bin/has-glyphs" e0a0 f09b f08c0 2>/dev/null && nf_on=1
fi
if [[ -n $nf_on ]]; then
	nf_branch=$' '   # U+E0A0 nf-pl-branch
	nf_github=$' '   # U+F09B nf-fa-github
	nf_ssh=$'\U000F08C0 '  # U+F08C0 nf-md-ssh
fi

prompt_git() {
	local git_status='' branch=''

	if command git rev-parse --is-inside-work-tree &>/dev/null; then
		if [[ "$(command git rev-parse --is-inside-git-dir 2>/dev/null)" == "false" ]]; then
			command git update-index --really-refresh -q &>/dev/null

			command git diff --quiet --ignore-submodules --cached || git_status+='+'
			command git diff --quiet --ignore-submodules -- || git_status+='!'
			[[ -n "$(command git ls-files --others --exclude-standard)" ]] && git_status+='?'
			command git rev-parse --verify refs/stash &>/dev/null && git_status+='$'
		fi

		branch="$(command git symbolic-ref --quiet --short HEAD 2>/dev/null || \
			command git rev-parse --short HEAD 2>/dev/null || \
			echo '(unknown)')"

		# Commits ahead/behind upstream. Plain ↑/↓ (not Nerd Font ⇡/⇣, which
		# SauceCodePro NFM lacks) so this renders in any terminal unguarded.
		local arrows='' counts
		counts="$(command git rev-list --left-right --count '@{upstream}...HEAD' 2>/dev/null)"
		if [[ -n $counts ]]; then
			local behind="${counts%%[^0-9]*}" ahead="${counts##*[^0-9]}"
			(( ahead )) && arrows+="↑${ahead}"
			(( behind )) && arrows+="↓${behind}"
			[[ -n $arrows ]] && arrows=" %F{yellow}${arrows}%f"
		fi

		if [[ -n $git_status ]]; then
			git_status=" %F{red}[$git_status]%f"
		fi

		local gh_user gh_segment=''
		gh_user="$(command git config github.user 2>/dev/null)"
		[[ -n $gh_user ]] && gh_segment=" %F{8}as%f %F{magenta}${nf_github}${gh_user}%f"

		print -n -- " %F{8}on%f %F{blue}${nf_branch}${branch}%f${git_status}${arrows}${gh_segment}"
	fi
}

user_segment="%F{yellow}%n%f"
[[ $USER == root ]] && user_segment="%F{red}%n%f"

host_segment="%F{cyan}%m%f"
[[ -n $SSH_TTY ]] && host_segment="%B%F{red}${nf_ssh}%m%f%b"

PROMPT=$'%B\n'
PROMPT+="${user_segment} %F{8}at%f ${host_segment} %F{8}in%f %F{green}%~%f"
PROMPT+='$(prompt_git)'
PROMPT+=$'\n%F{8}$ %f%b'

PROMPT2=$'%F{yellow}→ %f'

precmd() {
	print -Pn "\e]0;%~\a"
}
