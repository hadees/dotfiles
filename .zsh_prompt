#!/usr/bin/env zsh

# Shell prompt — Base16 Eighties with a darkened background. Colors are fixed
# 256-palette indices (not ANSI 0-15), so each segment/state gets its own
# distinct hue. Indices approximate the Eighties pastels, plus a few extras:
#   grey 243  fg 252  red 210  orange 209  yellow 221  green 151  cyan 80
#   blue 110  magenta 182  brown 173  teal 79  rose 175  lime 185
#   purple 104  peach 216
# Nerd Font glyphs (branch , github , ssh 󰣀) are shown only when
# ~/bin/has-glyphs confirms the terminal font renders them (over ssh: when
# the client is iTerm); other terminals degrade to plain text.

if [[ $COLORTERM = gnome-* && $TERM = xterm ]] && infocmp gnome-256color >/dev/null 2>&1; then
	export TERM='gnome-256color'
elif infocmp xterm-256color >/dev/null 2>&1; then
	export TERM='xterm-256color'
fi

autoload -Uz colors && colors
setopt PROMPT_SUBST

# Base16 Eighties palette as 256-color indices (documented above). Fixed, not
# theme-tracking — distinct hues to denote different prompt elements/states.
c_grey=243 c_fg=252 c_red=210 c_orange=209 c_yellow=221 c_green=151 c_cyan=80
c_blue=110 c_magenta=182 c_brown=173 c_teal=79 c_rose=175 c_lime=185 c_purple=104 c_peach=216

# We render the active Python venv ourselves (prompt_venv); suppress the
# activate script's own "(venv)" prefix so it isn't shown twice.
export VIRTUAL_ENV_DISABLE_PROMPT=1

# Nerd Font glyphs. Locally, has-glyphs asks CoreText whether the terminal's
# configured font can actually render them (cached). Over ssh the remote host
# can't inspect the local machine's fonts, so iTerm identity (LC_TERMINAL,
# forwarded by iTerm) stays as the proxy. Either way the fallback is plain
# text.
# nf_github replaces the plain-text "@" rather than adding to it: icons
# stand in for words (cf. oh-my-posh's UpstreamIcon, shown bare before the
# name), so the segment reads " user" with glyphs and "@user" without.
nf_branch='' nf_github='@' nf_ssh='' nf_python='' nf_direnv='' nf_on=''
if [[ -n $SSH_TTY ]]; then
	[[ $LC_TERMINAL == iTerm2 ]] && nf_on=1
elif [[ -x $HOME/bin/has-glyphs ]]; then
	"$HOME/bin/has-glyphs" e0a0 f09b f08c0 2>/dev/null && nf_on=1
fi
if [[ -n $nf_on ]]; then
	nf_branch=$' '   # U+E0A0 nf-pl-branch
	nf_github=$' '   # U+F09B nf-fa-github
	nf_ssh=$'\U000F08C0 '  # U+F08C0 nf-md-ssh
	# Python glyph for the venv segment, gated on its own (like the
	# statusline's spinner) so a font with the core glyphs but not this one
	# still shows the venv name as plain text. Over ssh we can't probe the
	# local font, so iTerm identity already vouched for it via nf_on.
	if [[ -n $SSH_TTY ]] || "$HOME/bin/has-glyphs" e73c 2>/dev/null; then
		nf_python=$'\U0000E73C '  # U+E73C nf-dev-python
	fi
	# Leaf glyph for the direnv segment, gated on its own like nf_python.
	if [[ -n $SSH_TTY ]] || "$HOME/bin/has-glyphs" f06c 2>/dev/null; then
		nf_direnv=$'\U0000F06C '  # U+F06C nf-fa-leaf
	fi
fi

prompt_venv() {
	# Require the venv to still exist on disk: if it was deleted while active
	# (or direnv left VIRTUAL_ENV stuck after its .envrc was removed), hide the
	# segment rather than advertise a venv that's gone.
	[[ -n $VIRTUAL_ENV && -d $VIRTUAL_ENV ]] || return
	# Show the venv's own name, but for the conventional ".venv"/"venv"
	# layout that name is uninformative — use the project dir holding it.
	local name=${VIRTUAL_ENV:t}
	[[ $name == (.venv|venv|.env|env) ]] && name=${VIRTUAL_ENV:h:t}
	if [[ -n $nf_python ]]; then
		print -n -- "%F{$c_magenta}${nf_python}${name}%f "
	else
		print -n -- "%F{$c_magenta}(${name})%f "
	fi
}

prompt_direnv() {
	# DIRENV_DIR is set whenever an .envrc is loaded (the venv segment keys off
	# VIRTUAL_ENV; this is the broader "an .envrc is active" signal and can
	# co-occur with it). The value is the .envrc dir prefixed with '-'.
	# Require the .envrc to still exist: direnv doesn't unload when its .envrc
	# is deleted while loaded, leaving DIRENV_DIR stuck; gating on the file
	# keeps the stale value from showing in unrelated directories.
	[[ -n $DIRENV_DIR && -e ${DIRENV_DIR#-}/.envrc ]] || return
	local name=${${DIRENV_DIR#-}:t}
	if [[ -n $nf_direnv ]]; then
		print -n -- "%F{$c_teal}${nf_direnv}${name}%f "
	else
		print -n -- "%F{$c_teal}(direnv:${name})%f "
	fi
}

prompt_git() {
	local git_status='' branch=''

	if command git rev-parse --is-inside-work-tree &>/dev/null; then
		if [[ "$(command git rev-parse --is-inside-git-dir 2>/dev/null)" == "false" ]]; then
			command git update-index --really-refresh -q &>/dev/null

			# Each flag gets its own color: staged green, unstaged yellow,
			# untracked blue, stashed magenta.
			command git diff --quiet --ignore-submodules --cached || git_status+="%F{$c_green}+%f"
			command git diff --quiet --ignore-submodules -- || git_status+="%F{$c_yellow}!%f"
			[[ -n "$(command git ls-files --others --exclude-standard)" ]] && git_status+="%F{$c_blue}?%f"
			command git rev-parse --verify refs/stash &>/dev/null && git_status+="%F{$c_magenta}\$%f"
		fi

		branch="$(command git symbolic-ref --quiet --short HEAD 2>/dev/null || \
			command git rev-parse --short HEAD 2>/dev/null || \
			echo '(unknown)')"

		# Commits ahead/behind upstream. Plain ↑/↓ (not Nerd Font ⇡/⇣, which
		# SauceCodePro NFM lacks) so this renders in any terminal unguarded.
		local arrows='' counts
		counts="$(command git rev-list --left-right --count '@{upstream}...HEAD' 2>/dev/null)"
		if [[ -n $counts ]]; then
			local behind="${counts%%[^0-9]*}" ahead="${counts##*[^0-9]}"
			(( ahead )) && arrows+="%F{$c_lime}↑${ahead}%f"
			(( behind )) && arrows+="%F{$c_orange}↓${behind}%f"
			[[ -n $arrows ]] && arrows=" ${arrows}"
		fi

		if [[ -n $git_status ]]; then
			git_status=" %F{$c_grey}[%f${git_status}%F{$c_grey}]%f"
		fi

		local gh_user gh_segment=''
		gh_user="$(command git config github.user 2>/dev/null)"
		[[ -n $gh_user ]] && gh_segment=" %F{$c_grey}as%f %F{$c_purple}${nf_github}${gh_user}%f"

		print -n -- " %F{$c_grey}on%f %F{$c_blue}${nf_branch}${branch}%f${git_status}${arrows}${gh_segment}"
	fi
}

user_segment="%F{$c_yellow}%n%f"
[[ $USER == root ]] && user_segment="%F{$c_red}%n%f"

host_segment="%F{$c_cyan}%m%f"
[[ -n $SSH_TTY ]] && host_segment="%B%F{$c_peach}${nf_ssh}%m%f%b"

PROMPT=$'%B\n'
PROMPT+='$(prompt_venv)'
PROMPT+='$(prompt_direnv)'
PROMPT+="${user_segment} %F{$c_grey}at%f ${host_segment} %F{$c_grey}in%f %F{$c_green}%~%f"
PROMPT+='$(prompt_git)'
# Trailing $ is grey on success, red when the last command exited nonzero.
PROMPT+=$'\n'"%(?.%F{$c_grey}.%F{$c_red})\$ %f%b"

PROMPT2="%F{$c_yellow}→ %f"

precmd() {
	print -Pn "\e]0;%~\a"
}
